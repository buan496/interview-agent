# Interview Agent local development environment.
# Do not use this file as production configuration.

# App config
APP_ENV=development
SERVICE_NAME=Interview Agent
API_PREFIX=/api
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
CORS_ORIGINS=http://localhost:3000

# Database / infrastructure config
POSTGRES_DB=interview_agent
POSTGRES_USER=interview
POSTGRES_PASSWORD=local-dev-only
DATABASE_URL=postgresql+asyncpg://interview:local-dev-only@postgres:5432/interview_agent
REDIS_URL=redis://redis:6379/0

# Auth config
# Development/test only. Production must set AUTH_DEV_CODE_ENABLED=false and must not use 000000.
AUTH_DEV_CODE_ENABLED=true
AUTH_DEV_CODE=000000
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Production required: set JWT_SECRET_KEY, TOKEN_SECRET, or JWT_SECRET to a strong secret.
JWT_SECRET=local-dev-only-change-me
SMS_PROVIDER_KEY=

# Admin config
# Comma-separated phone allowlist. Missing value is allowed but means no admin user.
ADMIN_PHONES=13800000000

# LLM config
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45
LLM_PRICING_VERSION=llm-pricing-v1-2026-07

# Usage metering config
LLM_USAGE_METERING_ENABLED=true

# Model / audio config
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.siliconflow.cn/v1
WHISPER_MODEL=FunAudioLLM/SenseVoiceSmall

# Observability config
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
