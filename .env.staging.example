# Interview Agent staging environment template.
# Copy to .env.staging and replace every __CHANGE_ME__ value outside git.
# Do not commit real secrets, server IPs, provider keys, or production user data.

# App config
APP_ENV=staging
SERVICE_NAME=Interview Agent Staging
API_PREFIX=/api
API_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=https://staging.example.com/api
CORS_ORIGINS=https://staging.example.com

# Immutable release image tags. Prefer git SHA or release candidate tag, not latest.
IMAGE_TAG=__CHANGE_ME_RELEASE_IMAGE_TAG__
API_IMAGE=interview-agent-api:${IMAGE_TAG}
FRONTEND_IMAGE=interview-agent-frontend:${IMAGE_TAG}

# Database / infrastructure config
POSTGRES_DB=interview_agent_staging
POSTGRES_USER=interview
POSTGRES_PASSWORD=__CHANGE_ME_STAGING_POSTGRES_PASSWORD__
DATABASE_URL=postgresql+asyncpg://interview:__CHANGE_ME_STAGING_POSTGRES_PASSWORD__@postgres:5432/interview_agent_staging
REDIS_URL=redis://redis:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2

# Auth config
# Staging must not use the default development code path.
AUTH_DEV_CODE_ENABLED=false
AUTH_DEV_CODE=__DISABLED_IN_STAGING__
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_SECRET_KEY=__CHANGE_ME_STAGING_JWT_SECRET__
SMS_PROVIDER_KEY=__OPTIONAL_STAGING_SMS_PROVIDER_KEY__

# Admin / RBAC bootstrap config
ADMIN_PHONES=__OPTIONAL_MASKED_STAGING_ADMIN_PHONES__

# LLM config
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=__CHANGE_ME_OR_LEAVE_EMPTY_FOR_FALLBACK__
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45
LLM_PRICING_VERSION=llm-pricing-v1-2026-07
LLM_USAGE_METERING_ENABLED=true

# Redis-backed rate limit / quota config
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
REDIS_RATE_LIMIT_PREFIX=interview-agent:staging:rate-limit
LOGIN_RATE_LIMIT_PER_MINUTE=120
AUTH_PHONE_RATE_LIMIT_PER_HOUR=20
ANSWER_SUBMIT_RATE_LIMIT_PER_MINUTE=60
LLM_DAILY_TOKEN_QUOTA=1000000
LLM_MONTHLY_TOKEN_QUOTA=10000000
LLM_DAILY_CALL_QUOTA=1000

# Cache foundation config
CACHE_BACKEND=redis
CACHE_PREFIX=interview-agent:staging:cache

# Model / audio config
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
WHISPER_API_KEY=__OPTIONAL_STAGING_WHISPER_API_KEY__
WHISPER_BASE_URL=https://api.siliconflow.cn/v1
WHISPER_MODEL=FunAudioLLM/SenseVoiceSmall

# Observability config
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
